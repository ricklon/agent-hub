# ── LLM provider ─────────────────────────────────────────────────────────────
#
# agent-hub uses an OpenAI-compatible API for the language model.
# The default points to OpenRouter, which gives you access to many models
# (including free-tier ones) with a single API key.
#
# Get a free OpenRouter key at https://openrouter.ai → Sign in → Keys
#
AGENT_HUB_LLM_OPENAI_API_KEY=sk-or-...
AGENT_HUB_LLM_OPENAI_BASE_URL=https://openrouter.ai/api/v1
AGENT_HUB_LLM_OPENAI_MODEL=google/gemma-3-27b-it

# To use OpenAI directly instead of OpenRouter:
# AGENT_HUB_LLM_OPENAI_API_KEY=sk-...
# AGENT_HUB_LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# AGENT_HUB_LLM_OPENAI_MODEL=gpt-4o-mini

# To use a local Ollama server:
# AGENT_HUB_LLM_OPENAI_BASE_URL=http://localhost:11434/v1
# AGENT_HUB_LLM_OPENAI_MODEL=llama3.2
# AGENT_HUB_LLM_OPENAI_API_KEY=ollama

# ── TTS (text-to-speech) ──────────────────────────────────────────────────────
#
# Default provider is Edge TTS (Microsoft, free, no key required).
# Change the voice to any name from: https://aka.ms/edge-tts-voices
# or run: uv run python -c "import asyncio,edge_tts; asyncio.run(edge_tts.list_voices())" | grep en-US
#
# AGENT_HUB_TTS_DEFAULT_PROVIDER=edge
# AGENT_HUB_TTS_EDGE_VOICE=en-US-AriaNeural

# ── ASR (speech recognition) ─────────────────────────────────────────────────
#
# Default ASR uses SenseVoiceSmall running locally (downloaded by just download-models).
# Fresh installs use the ONNX provider for faster CPU inference. Set persona
# asr_provider to funasr to use the torch fallback instead.
# If you want cloud Whisper instead, uncomment and set a key:
#
# AGENT_HUB_ASR_FUNASR_ONNX_MODEL_DIR=models/SenseVoiceSmall-onnx
# AGENT_HUB_ASR_FUNASR_ONNX_LANGUAGE=en
# AGENT_HUB_ASR_FUNASR_ONNX_INTRA_OP_NUM_THREADS=4
# AGENT_HUB_ASR_OPENAI_WHISPER_API_KEY=sk-...   # uses LLM key above if omitted
# AGENT_HUB_ASR_OPENAI_WHISPER_LANGUAGE=en

# ── Server networking ─────────────────────────────────────────────────────────
#
# AGENT_HUB_SERVER_HOST=0.0.0.0        # bind address (0.0.0.0 = all interfaces)
# AGENT_HUB_SERVER_WS_PORT=8000        # WebSocket voice session port
# AGENT_HUB_SERVER_HTTP_PORT=8003      # device check-in / OTA port
# AGENT_HUB_SERVER_DASHBOARD_PORT=8001 # dashboard UI port
# AGENT_HUB_SERVER_TIMEZONE=America/New_York # IANA timezone; handles DST
# AGENT_HUB_SERVER_TIMEZONE_OFFSET=-5        # fallback fixed UTC offset, in hours
#
# AGENT_HUB_SERVER_WEBSOCKET is the WebSocket URL sent back to devices on
# check-in so they know where to connect for voice sessions. Set this to
# your server's LAN IP (or hostname) when running on a machine that devices
# need to reach over the network. If omitted, the server auto-detects its
# local IP.
#
# AGENT_HUB_SERVER_WEBSOCKET=ws://192.168.1.39:8000/xiaozhi/v1/
